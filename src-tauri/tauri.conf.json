{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Meno",
  "version": "0.1.0",
  "identifier": "com.kfchem.meno",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Meno",
        "width": 1024,
        "height": 768,
        "minWidth": 640,
        "minHeight": 480,
        "dragDropEnabled": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default", "main"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/**/*"]
  }
}
